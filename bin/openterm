#!/usr/bin/bash

function open_con()
{
	for DIM; do
		konsole -p "TerminalColumns=${DIM%%:*}" -p "TerminalRows=${DIM##*:}" &
	done
}

function open_con_dir()
{
	pushd "$1" > /dev/null
	open_con 100:83 100:83
	popd > /dev/null
}

if [ $# -gt 0 ]; then
	for APP; do
		case "$APP" in
		f2c) open_con_dir ~/my-repos/file2config/ ;;
		sgm) open_con_dir ~/repos/suse/suse-get-maintainers/ ;;
		slh) open_con_dir ~/my-repos/slhelpers/ ;;
		esac
	done
	exit 0
fi

DESK="$(xdotool get_desktop)"
case "$DESK" in
	0)
	xdg-su -c 'cd; konsole -p TerminalColumns=164 -p TerminalRows=24' &
	open_con 80:42
	;;
	1) open_con 80:42 80:42 150:24 80:24 150:24 150:24
	;;
	2) open_con 133:25 100:42 80:42 150:24 80:24 150:24
	;;
esac
